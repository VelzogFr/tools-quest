# Copy this file to .env and set your connection string
# SQLite (default):
# DATABASE_URL=sqlite+pysqlite:///./quest_tool.db

# MySQL example:
# DATABASE_URL=mysql+pymysql://user:password@localhost:3306/your_database

# PostgreSQL example:
# DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/your_database

# Optional: override table list if your names differ
# TABLE_NAMES=npc,npc_template,npc_question,npc_reponse,quest_data,quest_objectif,quest_etape,item_template,monster_fr